# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Learnoon Academy
NEXT_PUBLIC_APP_SHORT_NAME=Learnoon
NEXT_PUBLIC_APP_SLOGAN=Apprends aujourd'hui. Réussis demain.

# Contact public
NEXT_PUBLIC_CONTACT_WHATSAPP=2250757228731
NEXT_PUBLIC_CONTACT_EMAIL=soroboss.bossimpact@gmail.com

# InsForge (public — safe for browser)
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# InsForge (server-only — never expose to the browser)
INSFORGE_SERVICE_KEY=

# YouTube Data API (Phase 2+)
YOUTUBE_API_KEY=

# Payment provider
# sandbox = simulateur (dev / preview). Bloqué en production Vercel sauf soft-launch.
# cinetpay = paiement automatique Mobile Money (Orange, MTN, Wave…)
PAYMENT_PROVIDER=sandbox
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret-change-me
# Soft-launch sandbox (déconseillé si des vrais clients paient) :
# ALLOW_SANDBOX_IN_PRODUCTION=true
# FORCE_PRODUCTION_GUARDS=true

# CinetPay (quand PAYMENT_PROVIDER=cinetpay)
# https://docs.cinetpay.com/
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=

# Cron / certificates
CRON_SECRET=
CERTIFICATE_SIGNING_SECRET=

# E-mail transactionnel = InsForge (insforge.emails.send) — plan payant requis
# Pas de SMTP / Resend / SendGrid. Reply-To public :
# NEXT_PUBLIC_CONTACT_EMAIL (déjà défini ci-dessus)

# WhatsApp Cloud API (Meta) — optionnel. Sans ces clés, l’app reste in-app + e-mail.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Paiement manuel Mobile Money + WhatsApp (si le PSP en ligne échoue)
# Numéro WhatsApp international sans + (ex. Côte d'Ivoire : 22507XXXXXXXX)
MANUAL_PAYMENT_WHATSAPP=2250757228731
MANUAL_PAYMENT_WHATSAPP_MESSAGE=Bonjour, j'ai payé mon abonnement Learnoon Academy (2000 FCFA). Voici la capture.
MANUAL_PAYMENT_ORANGE=0757228731
MANUAL_PAYMENT_ORANGE_NAME=Learnoon Academy
MANUAL_PAYMENT_MTN=
MANUAL_PAYMENT_MTN_NAME=Learnoon Academy
MANUAL_PAYMENT_WAVE=0757228731
MANUAL_PAYMENT_WAVE_NAME=Learnoon Academy
